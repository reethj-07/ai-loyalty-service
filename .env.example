# Application Settings
APP_NAME=Agentic Loyalty AI Service
ENVIRONMENT=local
LOG_LEVEL=INFO
REQUIRE_AUTH=true
TENANT_MODE=false

# Auth transport hardening
# Keep false in production to avoid leaking bearer tokens in URLs/logs.
ALLOW_QUERY_ACCESS_TOKEN=false
# Set true in production behind HTTPS when using cookie auth.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# Frontend URLs (comma-separated for multiple domains)
# Local: http://localhost:8080,http://localhost:8081,http://127.0.0.1:8080,http://127.0.0.1:8081
# Production: https://your-company-domain.com,https://your-company-app.vercel.app
FRONTEND_URLS=http://localhost:8080,http://localhost:8081

# Supabase Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# Redis (Optional - for KPI caching)
REDIS_URL=redis://localhost:6379

# Observability (optional in non-Docker deployments)
# Set OTEL_ENABLED=false on platforms where Jaeger/OTLP collector is not available.
OTEL_ENABLED=true
# Example local Docker value: http://jaeger:4317
OTEL_EXPORTER_OTLP_ENDPOINT=

# SendGrid Email Service
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourcompany.com
SENDGRID_FROM_NAME=Your Company Name

# Twilio SMS Service
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Stripe Payment System (Phase 3 - Optional)
STRIPE_API_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Push Notifications (Phase 3 - Optional)
FIREBASE_SERVER_KEY=your_firebase_key
APNS_KEY_ID=your_apns_key
APNS_TEAM_ID=your_team_id

# Feature Flags
ENABLE_ML_MODELS=true
ENABLE_EMAIL_SENDING=true
ENABLE_SMS_SENDING=true
ENABLE_REAL_TIME_UPDATES=false

# ML Model Settings
ML_MODEL_PATH=models/
ML_AUTO_RETRAIN=true
ML_MIN_TRAINING_SAMPLES=10
# Anthropic Claude API (Optional - for AI message generation)
# Get your key from: https://console.anthropic.com/
# If not set, system falls back to template-based messages
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# LLM Provider Selection (Phase 1)
# Options: groq | anthropic
# Default is groq for free-tier evaluator-friendly setup
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_api_key